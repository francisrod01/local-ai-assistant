{
  "id": null,
  "title": "Backend Telemetry",
  "tags": ["telemetry"],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(backend_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Token Consumption",
      "targets": [
        {
          "expr": "sum(rate(backend_tokens_total[5m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Ollama Requests",
      "targets": [
        {
          "expr": "sum(rate(ollama_requests_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Loaded Models",
      "targets": [
        {
          "expr": "ollama_models_loaded",
          "legendFormat": "count"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "refresh": "10s"
}