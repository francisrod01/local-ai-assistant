NODE_ENV=development
LOG_LEVEL=info

# Docker mount volumes
OLLAMA_VOLUME_PATH=/mnt/docker_volumes/ollama_data

# Optional persistent service volumes
# Leave REDISDATA_VOLUME_PATH blank or unset to use a named Docker volume
# (avoids permission issues when mounting arbitrary host directories).
REDISDATA_VOLUME_PATH=
LOKI_DATA_VOLUME_PATH=/mnt/docker_volumes/loki_data
PROMETHEUS_VOLUME_PATH=/mnt/docker_volumes/prometheus_data

# Databases
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb
# Used by host-side tools/scripts.
# For containerized backend, service hostname should be "postgres".
POSTGRES_URL=postgresql://user:password@postgres:5432/mydb

# LLM services
OLLAMA_URL=http://ollama:11434
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_STREAM_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_STREAM_READ_TIMEOUT_SECONDS=600
OLLAMA_WARMUP_TIMEOUT_SECONDS=90
OLLAMA_KEEP_ALIVE=15m
# Default model served by the backend.  Change to any Ollama-supported model
# (e.g. mistral:7b, qwen2.5:3b, gemma2:2b).  llama3.2:3b is the recommended
# default: best instruction-following quality at ~2.4 GB RAM for daily tasks.
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OLLAMA_NUM_PREDICT=1024
