NODE_ENV=development
LOG_LEVEL=info

# Docker mount volumes
OLLAMA_VOLUME_PATH=/mnt/docker_volumes/ollamadata
BACKEND_VOLUME_PATH=/mnt/docker_volumes/backend
FRONTEND_VOLUME_PATH=/mnt/docker_volumes/frontend

# Optional persistent service volumes
# Leave REDISDATA_VOLUME_PATH blank or unset to use a named Docker volume
# (avoids permission issues when mounting arbitrary host directories).
REDISDATA_VOLUME_PATH=
LOKI_DATA_VOLUME_PATH=/mnt/docker_volumes/loki-data
PROMETHEUS_VOLUME_PATH=/mnt/docker_volumes/prometheus-data

# Databases
POSTGRES_URL=postgres://user:password@localhost:5432/mydb

# LLM services
OLLAMA_URL=http://ollama:11434
